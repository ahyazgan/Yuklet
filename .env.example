# Supabase — proje anahtarlarini .env.local dosyasina kopyala (bu dosyayi degil)
# Supabase Dashboard -> Project Settings -> API Keys
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Yeni Supabase anahtar sistemi: "Publishable key" (sb_publishable_...)
# Tarayicida guvenle kullanilir (RLS koruyor). Eski projelerde "anon public" (eyJ...) de olabilir.
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# NOT: "Secret key" (sb_secret_...) ASLA buraya/git'e konmaz — sadece sunucu tarafi.

# Mobil (Capacitor) native Google girisi — platform basina client ID (KURULUM-GIRIS.md):
# ANDROID bu Web client ID'yi kullanir. Google Cloud -> Credentials -> "Web application".
# Ayrica ayni projede paket adi (com.yuklet.app) + SHA-1'li "Android" client TANIMLI olmali
# (buraya yazilmaz, sadece Google Cloud'da var olmali — yoksa giris sessizce reddedilir).
VITE_GOOGLE_WEB_CLIENT_ID=xxxxxx-xxxxxxxx.apps.googleusercontent.com

# iOS native Google girisi bu iOS client ID'yi kullanir.
# Google Cloud -> Credentials -> "iOS" client (bundle: com.yuklet.app).
# Client'i olusturunca cikan REVERSED CLIENT ID, ios/App/App/Info.plist'teki
# com.googleusercontent.apps.REVERSED-CLIENT-ID-DEGISTIR yer tutucusuna yazilmali.
VITE_GOOGLE_IOS_CLIENT_ID=xxxxxx-xxxxxxxx.apps.googleusercontent.com
