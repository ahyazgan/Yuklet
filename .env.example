# Supabase — proje anahtarlarini .env.local dosyasina kopyala (bu dosyayi degil)
# Supabase Dashboard -> Project Settings -> API Keys
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Yeni Supabase anahtar sistemi: "Publishable key" (sb_publishable_...)
# Tarayicida guvenle kullanilir (RLS koruyor). Eski projelerde "anon public" (eyJ...) de olabilir.
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# NOT: "Secret key" (sb_secret_...) ASLA buraya/git'e konmaz — sadece sunucu tarafi.

# Mobil (Capacitor) native Google girisi icin Web Client ID.
# Google Cloud -> APIs & Services -> Credentials -> "Web application" client ID.
# (Web tarayici girisi bunu kullanmaz; sadece native plugin icin.)
VITE_GOOGLE_WEB_CLIENT_ID=xxxxxx-xxxxxxxx.apps.googleusercontent.com
