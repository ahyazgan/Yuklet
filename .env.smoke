# Smoke test modu — Supabase KAPALI (localStorage modu).
# `npx vite --mode smoke` ile açılır; .env.local'daki gerçek anahtarları ezer
# (Vite öncelik: .env.[mode] > .env.local). Böylece scripts/smoke-test.mjs
# canlı veritabanına hiç dokunmadan uygulama akışlarını test eder.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=
